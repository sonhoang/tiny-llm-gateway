ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SESSION_SECRET=
STORE_ENCRYPTION_KEY=
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

PORT=4000

# Provider keys (comma-separated; persisted encrypted after first write)
GEMINI_KEYS=
QWEN_KEYS=

# Qwen OpenAI-compatible base (DashScope compatible-mode)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Local / any OpenAI-compatible API (LM Studio, vLLM, Ollama, custom gateways) ---
# Default base when using LOCAL_API_KEYS only (all keys share this URL).
# May be host root (https://api.example.com) or .../v1 — /v1/chat/completions is resolved automatically.
LOCAL_LLM_URL=http://host.docker.internal:11434/v1

# Bearer token(s) for that endpoint (comma-separated for rotation / load balance).
# Leave empty for no Authorization header (typical Ollama).
LOCAL_API_KEYS=

# Optional: per-endpoint URL + key pairs (comma-separated). Each entry:
#   https://host:port/v1|sk-your-key
#   https://host:port/v1          (no key, same as key empty)
# If set, LOCAL_PROVIDER_ENDPOINTS replaces LOCAL_API_KEYS + LOCAL_LLM_URL for stored local rows.
# LOCAL_PROVIDER_ENDPOINTS=

# Fallback order: comma-separated provider ids (gemini,qwen,local)
PROVIDER_FALLBACK=gemini,qwen,local
