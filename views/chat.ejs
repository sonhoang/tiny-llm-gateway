<!DOCTYPE html>
<html>
<head>
  <title>LLM Gateway — Test chat</title>
  <style>
    body { font-family: sans-serif; max-width: 720px; margin: 0 auto; padding: 24px; }
    nav a { margin-right: 16px; color: #555; }
    label { display: block; margin-top: 12px; font-size: 14px; }
    input[type=text], textarea { width: 100%; box-sizing: border-box; padding: 10px; border: 1px solid #ccc; border-radius: 6px; font-size: 14px; }
    textarea { min-height: 120px; resize: vertical; }
    button { margin-top: 12px; padding: 10px 20px; background: #1a1a2e; color: white; border: none; border-radius: 6px; cursor: pointer; }
    button:disabled { opacity: 0.6; cursor: wait; }
    #out { margin-top: 20px; padding: 16px; background: #f5f5f5; border-radius: 8px; white-space: pre-wrap; word-break: break-word; min-height: 60px; }
    .err { color: #c0392b; }
    .hint { color: #666; font-size: 13px; margin-top: 8px; }
  </style>
</head>
<body>
  <nav>
    <a href="/admin">Dashboard</a>
    <a href="/admin/providers">Providers (BYOK)</a>
    <a href="/admin/chat">Test LLM</a>
    <a href="/admin/logs">Logs</a>
    <a href="/admin/logout">Logout</a>
  </nav>
  <h1>Test LLM (admin)</h1>
  <% if (label) { %><p class="hint">Context: <strong><%= label %></strong> (same routing as <code>/v1/chat/completions</code>)</p><% } %>
  <p class="hint">Uses your configured provider keys and priorities. No gateway API key required (session only).</p>

  <label for="model">Model</label>
  <input type="text" id="model" value="gemini-1.5-flash" placeholder="e.g. gemini-1.5-flash, qwen-turbo, llama3" />

  <label for="message">Message</label>
  <textarea id="message" placeholder="Ask something…"></textarea>

  <button type="button" id="send">Send</button>

  <div id="out" aria-live="polite"></div>

  <script>
    const out = document.getElementById("out");
    const send = document.getElementById("send");
    send.addEventListener("click", async function () {
      const model = document.getElementById("model").value.trim() || "gemini-1.5-flash";
      const message = document.getElementById("message").value.trim();
      if (!message) {
        out.textContent = "Enter a message.";
        out.className = "err";
        return;
      }
      send.disabled = true;
      out.className = "";
      out.textContent = "…";
      try {
        const res = await fetch("/admin/api/chat-test", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ model, message })
        });
        const data = await res.json().catch(function () { return {}; });
        if (!res.ok) {
          out.className = "err";
          out.textContent = data.error || res.statusText || "Request failed";
          return;
        }
        out.textContent = (data.model ? "[" + data.model + "]\n\n" : "") + (data.reply || "");
      } catch (e) {
        out.className = "err";
        out.textContent = String(e);
      } finally {
        send.disabled = false;
      }
    });
  </script>
</body>
</html>
