<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>LLM Gateway - Dashboard</title>
  <style>
    body { font-family: sans-serif; max-width: 900px; margin: 0 auto; padding: 24px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 10px 12px; border: 1px solid #ddd; text-align: left; }
    th { background: #f0f0f0; }
    form.inline { display: inline; }
    input[type=text] { padding: 6px 10px; border: 1px solid #ccc; border-radius: 4px; }
    button { padding: 6px 14px; border-radius: 4px; border: none; cursor: pointer; }
    .btn-create { background: #1a1a2e; color: white; }
    .btn-revoke { background: #c0392b; color: white; }
    nav a { margin-right: 16px; color: #555; }
    .flash { background: #e8f4fd; border: 1px solid #90caf9; padding: 12px 16px; border-radius: 6px; margin-bottom: 20px; }
    .flash code { word-break: break-all; }
  </style>
</head>
<body>
  <nav>
    <a href="/admin">Dashboard</a>
    <a href="/admin/providers">Providers (BYOK)</a>
    <a href="/admin/chat">Test LLM</a>
    <a href="/admin/logs">Logs</a>
    <a href="/admin/logout">Logout</a>
  </nav>
  <h1>🧠 LLM Gateway Dashboard</h1>

  <% if (newKey) { %>
  <div class="flash">
    <strong>New API key</strong> — copy now; it will not be shown again.<br />
    <code><%= newKey %></code>
  </div>
  <% } %>

  <h2>Create API Key</h2>
  <form method="POST" action="/admin/keys/create">
    <input type="text" name="name" placeholder="Key label (e.g. my-app)" required />
    <button class="btn-create" type="submit">Create Key</button>
  </form>
  <p><em>The full key is only shown once after creation — copy it immediately.</em></p>

  <h2>Active Keys</h2>
  <table>
    <tr><th>Name</th><th>Key (masked)</th><th>Created</th><th>Last Used</th><th>Status</th><th>Test LLM</th><th>Action</th></tr>
    <% keys.forEach(k => { %>
    <tr>
      <td><%= k.name %></td>
      <td><code><%= k.key %></code></td>
      <td><%= new Date(k.createdAt).toLocaleString() %></td>
      <td><%= k.lastUsed ? new Date(k.lastUsed).toLocaleString() : "Never" %></td>
      <td><%= k.active ? "✅ Active" : "❌ Revoked" %></td>
      <td>
        <% if (k.active) { %>
        <a href="/admin/chat?label=<%= ec(k.name) %>">Test</a>
        <% } else { %>—<% } %>
      </td>
      <td>
        <% if (k.active) { %>
        <form class="inline" method="POST" action="/admin/keys/revoke">
          <input type="hidden" name="prefix" value="<%= k.key.split('...')[0] %>" />
          <button class="btn-revoke" type="submit" onclick="return confirm('Revoke this key?')">Revoke</button>
        </form>
        <% } %>
      </td>
    </tr>
    <% }) %>
  </table>
</body>
</html>
