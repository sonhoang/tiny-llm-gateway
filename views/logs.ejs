<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>LLM Gateway — Logs</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 1200px; margin: 0 auto; padding: 24px; background: #f4f4f5; }
    nav a { margin-right: 16px; color: #555; }
    pre.app-log { background: #1a1a2e; color: #eee; padding: 16px; border-radius: 8px; overflow-x: auto; font-size: 13px; line-height: 1.5; }
    .meta { color: #90caf9; }
    h1 { margin-top: 0; }
    h2 { margin-top: 32px; border-bottom: 2px solid #1a1a2e; padding-bottom: 6px; }
    table.summary { width: 100%; border-collapse: collapse; font-size: 13px; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
    th, td { padding: 10px 12px; border-bottom: 1px solid #e8e8e8; text-align: left; vertical-align: top; }
    th { background: #ececf1; font-weight: 600; }
    tr:last-child td { border-bottom: none; }
    code { font-size: 12px; }
    .ok { color: #155724; font-weight: 600; }
    .bad { color: #c0392b; font-weight: 600; }
    .hint { color: #666; font-size: 13px; }
    .mono { font-family: ui-monospace, "Cascadia Code", monospace; font-size: 12px; }
    /* LM Studio–style expandable JSON panels */
    .detail-cell { padding: 0 !important; border-bottom: 1px solid #d0d0d7 !important; background: #e8e8ed; }
    .lm-details { margin: 0; }
    .lm-details > summary {
      cursor: pointer; padding: 10px 14px; font-size: 13px; font-weight: 600;
      color: #2d6a4f; background: linear-gradient(180deg, #d8f3dc 0%, #cce3d4 100%);
      list-style: none; user-select: none;
    }
    .lm-details > summary::-webkit-details-marker { display: none; }
    .lm-details > summary::before { content: "▸ "; }
    .lm-details[open] > summary::before { content: "▾ "; }
    .lm-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 0;
      border-top: 1px solid #2b2b32;
    }
    @media (max-width: 900px) { .lm-grid { grid-template-columns: 1fr; } }
    .lm-panel {
      background: #252526; color: #d4d4d4; border-right: 1px solid #3c3c3c;
      min-height: 120px;
    }
    .lm-panel:last-child { border-right: none; }
    .lm-panel h4 {
      margin: 0; padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.06em; color: #cccccc; background: #2d2d30; border-bottom: 1px solid #3c3c3c;
    }
    .lm-pre {
      margin: 0; padding: 12px 14px; font-family: ui-monospace, "Cascadia Code", monospace;
      font-size: 12px; line-height: 1.45; white-space: pre-wrap; word-break: break-word;
      max-height: 420px; overflow: auto; color: #d4d4d4;
    }
  </style>
</head>
<body>
  <nav>
    <a href="/admin">Dashboard</a>
    <a href="/admin/providers">Providers (BYOK)</a>
    <a href="/admin/chat">Test LLM</a>
    <a href="/admin/logs">Logs</a>
    <a href="/admin/logout">Logout</a>
  </nav>
  <h1>Logs</h1>

  <h2>API calls (last 50)</h2>
  <p class="hint">Persisted to <code>data/api_calls.json</code>. JSON: <code>GET /admin/api/call-logs</code>. Expand a row for full request/response bodies (truncated for size).</p>
  <% var _calls = typeof apiCalls !== "undefined" && apiCalls ? apiCalls : []; %>
  <% var _fmt = typeof fmtJson === "function" ? fmtJson : function (o) { return JSON.stringify(o || {}, null, 2); }; %>
  <% if (_calls.length === 0) { %>
  <p class="hint">No chat completions recorded yet.</p>
  <% } else { %>
  <table class="summary">
    <tr>
      <th>Time</th>
      <th>Path</th>
      <th>Status</th>
      <th>ms</th>
      <th>Request model</th>
      <th>Msgs</th>
      <th>Response model</th>
      <th>Error</th>
    </tr>
    <% _calls.forEach(function (c) { %>
    <tr>
      <td class="mono"><%= c.ts %></td>
      <td><code><%= c.method %> <%= c.path %></code></td>
      <td class="<%= c.statusCode >= 200 && c.statusCode < 300 ? 'ok' : 'bad' %>"><%= c.statusCode %></td>
      <td><%= c.durationMs %></td>
      <td><%= c.model || "—" %></td>
      <td><%= c.messagesCount != null ? c.messagesCount : "—" %></td>
      <td><%= c.responseModel || "—" %></td>
      <td><%= c.error || "—" %></td>
    </tr>
    <tr>
      <td colspan="8" class="detail-cell">
        <details class="lm-details">
          <summary>Request &amp; response details (OpenAI-style JSON)</summary>
          <div class="lm-grid">
            <section class="lm-panel">
              <h4>Request</h4>
              <pre class="lm-pre"><%- _fmt(c.requestDetail) %></pre>
            </section>
            <section class="lm-panel">
              <h4>Response</h4>
              <pre class="lm-pre"><%- _fmt(c.responseDetail) %></pre>
            </section>
          </div>
        </details>
      </td>
    </tr>
    <% }); %>
  </table>
  <% } %>

  <h2>Application log (in-memory)</h2>
  <p class="hint">Last <%= entries.length %> diagnostic lines.</p>
  <pre class="app-log"><% entries.forEach(function (e) { %><span class="meta">[<%= e.ts %>] <%= e.level.toUpperCase() %></span> <%= e.msg %><% if (e.meta) { %> <%= e.meta %><% } %>
<% }); %></pre>
</body>
</html>
