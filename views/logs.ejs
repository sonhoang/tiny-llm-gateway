<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>LLM Gateway — Logs</title>
  <style>
    body { font-family: sans-serif; max-width: 1100px; margin: 0 auto; padding: 24px; }
    nav a { margin-right: 16px; color: #555; }
    pre { background: #1a1a2e; color: #eee; padding: 16px; border-radius: 8px; overflow-x: auto; font-size: 13px; line-height: 1.5; }
    .meta { color: #90caf9; }
    h2 { margin-top: 32px; border-bottom: 2px solid #1a1a2e; padding-bottom: 6px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { padding: 8px 10px; border: 1px solid #ddd; text-align: left; vertical-align: top; }
    th { background: #f0f0f0; }
    code { font-size: 12px; }
    .ok { color: #155724; }
    .bad { color: #c0392b; }
    .hint { color: #666; font-size: 13px; }
    .mono { font-family: ui-monospace, monospace; font-size: 12px; }
  </style>
</head>
<body>
  <nav>
    <a href="/admin">Dashboard</a>
    <a href="/admin/providers">Providers (BYOK)</a>
    <a href="/admin/chat">Test LLM</a>
    <a href="/admin/logs">Logs</a>
    <a href="/admin/logout">Logout</a>
  </nav>
  <h1>Logs</h1>

  <h2>API calls (last 50)</h2>
  <p class="hint">Persisted to <code>data/api_calls.json</code>. JSON: <code>GET /admin/api/call-logs</code> (same admin session cookie).</p>
  <% var _calls = typeof apiCalls !== "undefined" && apiCalls ? apiCalls : []; %>
  <% if (_calls.length === 0) { %>
  <p class="hint">No chat completions recorded yet.</p>
  <% } else { %>
  <table>
    <tr>
      <th>Time</th>
      <th>Path</th>
      <th>Status</th>
      <th>ms</th>
      <th>Request model</th>
      <th>Msgs</th>
      <th>Response model</th>
      <th>Error</th>
    </tr>
    <% _calls.forEach(function (c) { %>
    <tr>
      <td class="mono"><%= c.ts %></td>
      <td><code><%= c.method %> <%= c.path %></code></td>
      <td class="<%= c.statusCode >= 200 && c.statusCode < 300 ? 'ok' : 'bad' %>"><%= c.statusCode %></td>
      <td><%= c.durationMs %></td>
      <td><%= c.model || "—" %></td>
      <td><%= c.messagesCount != null ? c.messagesCount : "—" %></td>
      <td><%= c.responseModel || "—" %></td>
      <td><%= c.error || "—" %></td>
    </tr>
    <% }); %>
  </table>
  <% } %>

  <h2>Application log (in-memory)</h2>
  <p class="hint">Last <%= entries.length %> diagnostic lines.</p>
  <pre><% entries.forEach(function (e) { %><span class="meta">[<%= e.ts %>] <%= e.level.toUpperCase() %></span> <%= e.msg %><% if (e.meta) { %> <%= e.meta %><% } %>
<% }); %></pre>
</body>
</html>
