<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>LLM Gateway - Provider keys (BYOK)</title>
  <style>
    body { font-family: sans-serif; max-width: 1200px; margin: 0 auto; padding: 24px; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 28px; }
    th, td { padding: 8px 10px; border: 1px solid #ddd; text-align: left; vertical-align: top; }
    th { background: #f0f0f0; font-size: 13px; }
    form.inline { display: inline; margin-right: 6px; }
    input[type=text], input[type=number] { padding: 6px 8px; border: 1px solid #ccc; border-radius: 4px; max-width: 100%; box-sizing: border-box; }
    button, .btn { padding: 5px 12px; border-radius: 4px; border: none; cursor: pointer; font-size: 13px; }
    .btn-save { background: #1a1a2e; color: white; }
    .btn-del { background: #c0392b; color: white; }
    .btn-soft { background: #ecf0f1; color: #333; }
    nav a { margin-right: 16px; color: #555; }
    h2 { margin-top: 32px; border-bottom: 2px solid #1a1a2e; padding-bottom: 6px; }
    .hint { color: #666; font-size: 13px; margin-bottom: 12px; }
    .mono { font-family: ui-monospace, monospace; font-size: 12px; word-break: break-all; }
    .add-box { background: #f9f9f9; padding: 16px; border-radius: 8px; margin-bottom: 24px; }
    .add-box label { display: block; margin-top: 8px; font-size: 13px; }
    .pill { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 12px; }
    .pill-on { background: #d4edda; color: #155724; }
    .pill-warn { background: #fff3cd; color: #856404; }
    .meta-form input[type=text] { max-width: 220px; }
  </style>
</head>
<body>
  <nav>
    <a href="/admin">Dashboard</a>
    <a href="/admin/providers">Providers (BYOK)</a>
    <a href="/admin/chat">Test LLM</a>
    <a href="/admin/logs">Logs</a>
    <a href="/admin/logout">Logout</a>
  </nav>
  <h1>Provider keys (BYOK)</h1>
  <p class="hint">Each row stores the upstream <strong>model</strong> id (required when adding). API default is <code>auto</code> (omit <code>model</code>, empty, or literal <code>auto</code>): the gateway tries <strong>all</strong> rows in <strong>priority</strong> order. If the client sets <code>model</code> to anything else, <strong>only</strong> rows with that exact configured model are used (priority fallback among them); if none match, the gateway returns an error. The name <code>auto</code> is reserved. Keys: <code>data/provider_keys.enc</code>.</p>

  <% var _sections = typeof sections !== "undefined" && sections ? sections : []; %>
  <% for (var si = 0; si < _sections.length; si++) { %>
  <% var sec = _sections[si]; %>
    <h2><%= sec.label %></h2>
    <table>
      <tr>
        <th>Prio</th>
        <th>On</th>
        <th>API key</th>
        <th>Model &amp; host</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
      <% for (var ri = 0; ri < sec.rows.length; ri++) { %>
      <% var row = sec.rows[ri]; %>
      <tr>
        <td>
          <form class="inline" method="POST" action="/admin/providers/priority">
            <input type="hidden" name="provider" value="<%= sec.provider %>" />
            <input type="hidden" name="id" value="<%= row.id %>" />
            <input type="number" name="priority" value="<%= row.priority %>" style="width:64px" />
            <button class="btn btn-save" type="submit">Set</button>
          </form>
        </td>
        <td>
          <form class="inline" method="POST" action="/admin/providers/toggle">
            <input type="hidden" name="provider" value="<%= sec.provider %>" />
            <input type="hidden" name="id" value="<%= row.id %>" />
            <input type="hidden" name="enabled" value="<%= row.enabled ? 'false' : 'true' %>" />
            <button class="btn <%= row.enabled ? 'btn-soft' : 'btn-save' %>" type="submit"><%= row.enabled ? 'Disable' : 'Enable' %></button>
          </form>
        </td>
        <td class="mono"><%= row.keyMasked %></td>
        <td>
          <form class="meta-form" method="POST" action="/admin/providers/update-meta" style="display:flex;flex-direction:column;gap:6px;align-items:flex-start;">
            <input type="hidden" name="provider" value="<%= sec.provider %>" />
            <input type="hidden" name="id" value="<%= row.id %>" />
            <input type="text" name="model" value="<%= row.model %>" title="Client + upstream model id" placeholder="model id" style="width:min(100%,280px)" />
            <input type="text" name="host" value="<%= row.host || '' %>" placeholder="host (optional — Google / Ollama default if empty)" title="API base URL" style="width:min(100%,400px)" />
            <button class="btn btn-save" type="submit">Save model &amp; host</button>
          </form>
        </td>
        <td>
          <% if (row.enabled === false) { %>
          <span class="pill pill-warn">Disabled</span>
          <% } else if (row.exhausted) { %>
          <span class="pill pill-warn">Auto-paused (401/403/429)</span>
          <% } else { %>
          <span class="pill pill-on">OK</span>
          <% } %>
        </td>
        <td>
          <% if (row.exhausted) { %>
          <form class="inline" method="POST" action="/admin/providers/reactivate">
            <input type="hidden" name="provider" value="<%= sec.provider %>" />
            <input type="hidden" name="id" value="<%= row.id %>" />
            <button class="btn btn-soft" type="submit">Clear auto-pause</button>
          </form>
          <% } %>
          <form class="inline" method="POST" action="/admin/providers/delete" onsubmit="return confirm('Delete this row?');">
            <input type="hidden" name="provider" value="<%= sec.provider %>" />
            <input type="hidden" name="id" value="<%= row.id %>" />
            <button class="btn btn-del" type="submit">Delete</button>
          </form>
          <div style="margin-top:8px">
            <form method="POST" action="/admin/providers/rotate-key" style="display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
              <input type="hidden" name="provider" value="<%= sec.provider %>" />
              <input type="hidden" name="id" value="<%= row.id %>" />
              <input type="text" name="newKey" placeholder="Rotate API key" style="flex:1; min-width:140px" />
              <button class="btn btn-save" type="submit">Rotate key</button>
            </form>
          </div>
        </td>
      </tr>
      <% } %>
    </table>

    <div class="add-box">
      <strong>Add <%= sec.label %> row</strong>
      <form method="POST" action="/admin/providers/add" style="margin-top:10px">
        <input type="hidden" name="provider" value="<%= sec.provider %>" />
        <label>API key <% if (sec.provider === "local") { %>(optional if host-only / no Bearer)<% } else { %>(required)<% } %></label>
        <input type="text" name="key" style="width:100%; max-width:480px" placeholder="<%= sec.provider === 'local' ? 'Bearer or empty' : 'Google AI key' %>" />
        <label>Model (upstream id; also used when the client sends <code>model</code> to select this row)</label>
        <input type="text" name="model" style="width:100%; max-width:480px" placeholder="<%= sec.provider === 'gemini' ? 'gemini-1.5-flash' : 'llama3' %>" required />
        <label>Host (API base — optional)</label>
        <input type="text" name="host" style="width:100%; max-width:560px" placeholder="<%= sec.provider === 'gemini' ? 'https://generativelanguage.googleapis.com' : 'http://127.0.0.1:11434/v1' %>" />
        <label>Priority (optional; lower = tried first among same model)</label>
        <input type="number" name="priority" placeholder="e.g. 0" style="width:120px" />
        <div style="margin-top:10px">
          <button class="btn btn-save" type="submit">Add</button>
        </div>
      </form>
    </div>
  <% } %>

</body>
</html>
